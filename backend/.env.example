# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce_db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d

# Frontend URL (for CORS + payment redirect callbacks)
CLIENT_URL=http://localhost:5173

# ---- JazzCash Mobile Account (Sandbox) ----
# Get these from https://sandbox.jazzcash.com.pk merchant portal
JAZZCASH_MERCHANT_ID=MC12345
JAZZCASH_PASSWORD=xxxxxx
JAZZCASH_INTEGRITY_SALT=xxxxxxxxxx
JAZZCASH_RETURN_URL=http://localhost:5000/api/payments/jazzcash/callback
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchant/pay

# ---- EasyPaisa (Sandbox) ----
EASYPAISA_STORE_ID=1234
EASYPAISA_ACCOUNT_NUM=03xxxxxxxxx
EASYPAISA_HASH_KEY=xxxxxxxxxx
EASYPAISA_RETURN_URL=http://localhost:5000/api/payments/easypaisa/callback
